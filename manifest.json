{
    "manifest_version": 3,
    "name": "TabDeep",
    "version": "1.0.0",
    "description": "Tab history analyzer — deep visit insights, cross-device sync, and forensic-level browsing analytics. 100% private.",
    "permissions": [
      "sessions",
      "tabs",
      "history",
      "favicon",
      "storage"
    ],
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "icons/TabDeep Icon 16x16.png",
        "32": "icons/TabDeep Icon 32x32.png",
        "48": "icons/TabDeep Icon 48x48.png",
        "128": "icons/TabDeep Icon 128x128.png"
      }
    },
    "icons": {
      "16": "icons/TabDeep Icon 16x16.png",
      "32": "icons/TabDeep Icon 32x32.png",
      "48": "icons/TabDeep Icon 48x48.png",
      "128": "icons/TabDeep Icon 128x128.png"
    },
    "background": {
      "service_worker": "background.js"
    }
  }